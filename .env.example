# ── Copy this file to .env and fill in your keys ─────────────────────────
# NEVER commit .env to Git — it is already in .gitignore

# LLM provider (Person 1 sets this up, everyone uses it)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...        # uncomment if switching to GPT-4o

# Search tool — Person 2
# Free tier: 1000 searches/month → https://tavily.com
TAVILY_API_KEY=tvly-...

# Vector store — Person 3
# Free tier: 1 cluster, 1GB → https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Optional: LangSmith tracing (strongly recommended for debugging)
# https://smith.langchain.com → create a project called "research-assistant"
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=research-assistant
