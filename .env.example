# ── Copy this file to .env and fill in your keys ─────────────────────────
# NEVER commit .env to Git — it is already in .gitignore

# LLM provider (Person 1 sets this up, everyone uses it)
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=...
GOOGLE_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...        # uncomment if switching to GPT-4o

# Search tool — Person 2
# Free tier: 1000 searches/month → https://tavily.com
GOOGLE_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=research-assistant
